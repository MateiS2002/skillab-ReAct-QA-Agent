# Choose the LLM provider: "openai" or "litellm"
LLM_PROVIDER=openai

# OpenAI provider configuration
# Recommended for reliable homework testing.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-nano-2025-08-07

# LiteLLM provider configuration
# Use this if running a local LiteLLM proxy backed by Ollama.
LITELLM_URL=http://localhost:4000/chat/completions
LITELLM_MODEL=gemma